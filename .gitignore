*.tgz
.cache/

# Stray tsc emit alongside source (we want emit only in dist/)
packages/shared/src/*.d.ts
packages/shared/src/*.js

# bin shim is hand-authored ESM and IS committed to git.
# Listed here as a reminder; no ignore rule for it.

# Claude Code harness — per-project settings, agent worktrees, hooks.
# Contains local credentials in settings.local.json; never publish.
.claude/

# Test coverage
coverage/

